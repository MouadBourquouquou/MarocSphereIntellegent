spring.application.name=maroc-sphere

# PostgreSQL
spring.datasource.url=jdbc:postgresql://${DB_HOST:localhost}:5432/marocsphere
spring.datasource.username=${DB_USERNAME:postgres}
spring.datasource.password=${DB_PASSWORD:postgres}
spring.datasource.driver-class-name=org.postgresql.Driver

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect

# JWT
jwt.secret=marocsphere-dev-secret-key-change-in-production-min-32-chars
jwt.expiration=86400000

# Server
server.port=8080

# Frontend
app.cors.allowed-origins=${FRONTEND_ORIGINS:http://localhost:4200,http://127.0.0.1:4200}
